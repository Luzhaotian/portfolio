{
  "name": "luzhaotian-portfolio",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run clean && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx,.mjs,.cjs --max-warnings 0",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx,.mjs,.cjs --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rm -rf .next",
    "fetch:blogs": "node scripts/fetch-csdn-blogs.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "{app,components,lib,data,types}/**/*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{js,ts,mjs}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "postcss*.cjs": "prettier --write",
    "*.{json,md,css,yml,yaml}": "prettier --write"
  },
  "dependencies": {
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "three": "^0.134.0",
    "vanta": "^0.5.24"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@types/three": "^0.134.0",
    "@unocss/postcss": "^66.7.2",
    "@unocss/preset-wind3": "^66.7.2",
    "@unocss/reset": "^66.7.2",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.19",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.4",
    "prettier": "^3.8.4",
    "typescript": "^5.8.3",
    "unocss": "^66.7.2"
  }
}
